{
  "name": "mact-cms",
  "version": "0.1.0",
  "private": true,
  "description": "MACT Case Management System — enterprise litigation management for Motor Accident Claims Tribunal advocates",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "prisma:generate": "npm run prisma:generate --workspace apps/api",
    "prisma:migrate": "npm run prisma:migrate --workspace apps/api",
    "prisma:studio": "npm run prisma:studio --workspace apps/api",
    "db:seed": "npm run db:seed --workspace apps/api"
  },
  "engines": {
    "node": ">=20"
  }
}
