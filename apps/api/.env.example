# PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mact_cms?schema=public"

# Auth
JWT_ACCESS_SECRET="change-me-to-a-long-random-string"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# App
PORT=4000
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# Storage (local for now; S3/R2 later)
STORAGE_DRIVER="local"
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB=25
